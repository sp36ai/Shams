# ============================================================================
# Shams al-Asrār — Environment Configuration
# ============================================================================
# Copy to `.env.local` and fill in real values.
# `.env.local` is gitignored — never commit secrets to repo.
#
# For local development:
#   - Leave Firebase keys blank (google-services.json is auto-configured)
#   - Set FIREBASE_EMULATOR_HOST to use local emulators
#   - Disable App Check debug token for emulator (optional)
#
# For production (Cloud Build):
#   - Keys are injected via GCP Secret Manager
#   - This file is not used in CI/CD; see DEPLOYMENT.md
# ============================================================================

# --- App Config ---
APP_ENV=development
APP_LOG_LEVEL=debug

# --- Firebase (Google Cloud Project) ---
# These are usually auto-configured in google-services.json
# Only needed if google-services.json is unavailable
FIREBASE_PROJECT_ID=shams-app-4d0e7
FIREBASE_APP_ID=1:1234567890:android:abcdef1234567890
FIREBASE_API_KEY=AIzaSyDxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Firebase Emulator (Local Development) ---
# When running Firebase emulators locally (npm run serve):
#   FIREBASE_EMULATOR_HOST=localhost:9099
# Uncomment for local testing; leave blank for production
FIREBASE_EMULATOR_HOST=

# --- Firebase App Check Debug Token (Mobile Local Testing) ---
# For testing on Android device/emulator with App Check enabled:
#   1. Firebase Console → App Check → Manage debug tokens
#   2. Create token
#   3. Copy token here
# Leave blank for production APKs (Play Integrity is used automatically)
FIREBASE_APP_CHECK_DEBUG_TOKEN_ANDROID=

# --- Google Play IAP (Server Verification) ---
# Service account credentials for verifyGooglePlayPurchase Cloud Function
# In Cloud Build: fetched from GCP Secret Manager (GOOGLE_PLAY_CLIENT_EMAIL, GOOGLE_PLAY_PRIVATE_KEY)
# For local testing: store in Secret Manager or emulator mock
# Cannot be populated here in plaintext due to length and sensitivity
GOOGLE_PLAY_CLIENT_EMAIL=
GOOGLE_PLAY_PRIVATE_KEY=

# --- Razorpay Payment Gateway ---
# For subscription handling via razorpayWebhook Cloud Function
# In Cloud Build: fetched from GCP Secret Manager
# For local testing: mock responses or test account
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# --- Analytics & Monitoring (Phase 2+) ---
# Optional: Sentry for crash reporting
SENTRY_DSN=

# --- Logging Level ---
# Options: trace, debug, info, warn, error, fatal
# Development: debug
# Production: info
LOG_LEVEL=debug
