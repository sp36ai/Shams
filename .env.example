# ============================================================================
# Shams al-Asrār — Environment Configuration
# ----------------------------------------------------------------------------
# Copy this file to `.env` (same folder) and fill in real values.
# `.env` is gitignored. Never commit secrets.
# ============================================================================

# --- Supabase (REQUIRED for auth + readings persistence) ---
# Get these from: https://app.supabase.com → Your Project → Settings → API
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_ANON_KEY=YOUR-ANON-KEY-HERE

# --- App config ---
APP_ENV=development
APP_LOG_LEVEL=debug

# --- Phase 4 (payments — leave blank for Phase 1) ---
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
GOOGLE_PLAY_PUBLIC_KEY=
STRIPE_PUBLISHABLE_KEY=
REVENUECAT_API_KEY_ANDROID=

# --- Phase 5 (analytics / crash — leave blank for Phase 1) ---
SENTRY_DSN=
