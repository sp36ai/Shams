# ============================================================================
# Shams al-Asrār — Environment Configuration
# ----------------------------------------------------------------------------
# Copy this file to `.env` and fill in real values.
# `.env` is gitignored. Never commit secrets.
# ============================================================================

# --- App config ---
APP_ENV=development
APP_LOG_LEVEL=debug

# --- Firebase App Check debug token (Android device/emulator local testing) ---
# 1. Firebase Console → App Check → Manage debug tokens → Create token
# 2. Register the printed token in the Console so the backend accepts it
# Leave blank for production builds — Play Integrity is used automatically.
FIREBASE_APP_CHECK_DEBUG_TOKEN_ANDROID=

# --- Payments (leave blank until Razorpay account is live) ---
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# --- Analytics / crash reporting (leave blank for Phase 1) ---
SENTRY_DSN=
