{
  "name": "shamsalasrar",
  "version": "0.1.0",
  "private": true,
  "description": "Shams al-Asrar - local RKP horary app powered by a deterministic judgment engine.",
  "scripts": {
    "android": "react-native run-android",
    "start": "react-native start",
    "start:reset": "react-native start --reset-cache",
    "build:android:debug": "cd android && gradlew assembleDebug",
    "build:android:release": "cd android && gradlew assembleRelease",
    "bundle:android": "cd android && gradlew bundleRelease",
    "clean:android": "cd android && gradlew clean",
    "lint": "eslint . --ext .ts,.tsx --max-warnings=0",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,json}\"",
    "test": "jest --testPathIgnorePatterns=firestore.rules.test.ts",
    "test:watch": "jest --watch --testPathIgnorePatterns=firestore.rules.test.ts",
    "test:coverage": "jest --coverage --testPathIgnorePatterns=firestore.rules.test.ts",
    "test:rules": "jest firestore.rules.test.ts --testEnvironment node",
    "validate:firebase:predeploy": "powershell -ExecutionPolicy Bypass -File scripts/Validate-FirebasePredeploy.ps1",
    "postinstall": "npx patch-package || echo \"No patches\""
  },
  "dependencies": {
    "@react-native-firebase/app": "^19.3.0",
    "@react-native-firebase/app-check": "^19.3.0",
    "@react-native-firebase/auth": "^19.3.0",
    "@react-native-firebase/functions": "^19.3.0",
    "@react-native-google-signin/google-signin": "^16.1.2",
    "@react-navigation/bottom-tabs": "^6.6.1",
    "@react-navigation/native": "^6.1.18",
    "@react-navigation/native-stack": "^6.11.0",
    "react": "18.2.0",
    "react-native": "0.74.5",
    "react-native-gesture-handler": "2.16.2",
    "react-native-mmkv": "^2.12.2",
    "react-native-reanimated": "^3.16.7",
    "react-native-safe-area-context": "^4.10.9",
    "react-native-screens": "^3.34.0",
    "react-native-svg": "15.3.0",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@babel/preset-env": "^7.20.0",
    "@babel/runtime": "^7.20.0",
    "@firebase/rules-unit-testing": "^3.0.4",
    "@react-native/babel-preset": "0.74.87",
    "@react-native/eslint-config": "0.74.87",
    "@react-native/metro-config": "0.74.87",
    "@react-native/typescript-config": "0.74.87",
    "@types/jest": "^29.5.12",
    "@types/react": "18.2.79",
    "@types/react-test-renderer": "^18.0.0",
    "babel-jest": "^29.6.3",
    "babel-plugin-module-resolver": "^5.0.2",
    "eslint": "^8.19.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "firebase": "^10.14.0",
    "jest": "^29.6.3",
    "patch-package": "^8.0.0",
    "prettier": "^3.3.3",
    "react-test-renderer": "18.2.0",
    "typescript": "^5.5.4"
  },
  "engines": {
    "node": ">=18"
  },
  "jest": {
    "preset": "react-native",
    "setupFiles": ["<rootDir>/jest.setup.js"],
    "transformIgnorePatterns": [
      "node_modules/(?!(jest-)?react-native|@react-native|@react-navigation|react-native-mmkv|react-native-reanimated|react-native-svg)"
    ],
    "moduleNameMapper": {
      "react-native-mmkv": "<rootDir>/__mocks__/react-native-mmkv.js"
    },
    "moduleFileExtensions": [
      "ts",
      "tsx",
      "js",
      "jsx",
      "json",
      "node"
    ]
  }
}
