# Shams al-Asrār — mobile app environment variables
# ─────────────────────────────────────────────────────────────────────────────
# Firebase config comes from google-services.json (Android) — not from here.
# This file holds RN-side runtime flags read via process.env / react-native-config.
#
# Never commit real credentials to version control. This file is in .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# Set to "true" to route Cloud Function calls to the local Firebase Emulator
# (localhost:5001) instead of production (asia-south1).
REACT_APP_USE_EMULATOR=false

# Application environment — controls log verbosity and dev-only UI.
APP_ENV=development
APP_LOG_LEVEL=debug

# ── Payments (Phase 4 — leave blank until payment integration) ───────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
GOOGLE_PLAY_PUBLIC_KEY=
STRIPE_PUBLISHABLE_KEY=
REVENUECAT_API_KEY_ANDROID=

# ── Analytics / Crash reporting (Phase 5 — leave blank until integrated) ─────
SENTRY_DSN=
