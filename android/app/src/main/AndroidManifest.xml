<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- ═══ Required for app function ═══ -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- ═══ Prashna chart requires GPS coords (city-level fine) ═══ -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />

    <!-- ═══ Phase 4: Google Play Billing (subscriptions) ═══ -->
    <uses-permission android:name="com.android.vending.BILLING" />

    <!-- ═══ Phase 5: Push notifications for planetary windows (Android 13+) ═══ -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- ═══ Network state for offline-handling UX ═══ -->
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- ═══ Hardware features (none required-true; app must run on tablets too) ═══ -->
    <uses-feature
        android:name="android.hardware.location.gps"
        android:required="false" />

    <queries>
        <!-- For opening external links (privacy policy, terms) -->
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <data android:scheme="https" />
        </intent>
    </queries>

    <application
        android:name=".MainApplication"
        android:label="@string/app_name"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:allowBackup="false"
        android:fullBackupContent="false"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:theme="@style/AppTheme"
        android:usesCleartextTraffic="false"
        android:networkSecurityConfig="@xml/network_security_config"
        android:supportsRtl="true"
        tools:targetApi="34">

        <activity
            android:name=".MainActivity"
            android:label="@string/app_name"
            android:configChanges="keyboard|keyboardHidden|orientation|screenLayout|screenSize|smallestScreenSize|uiMode|fontScale|locale|layoutDirection"
            android:launchMode="singleTask"
            android:windowSoftInputMode="adjustResize"
            android:exported="true"
            android:theme="@style/SplashTheme">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>
</manifest>
