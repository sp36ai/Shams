<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- Base application theme — applied AFTER splash. -->
    <style name="AppTheme" parent="Theme.AppCompat.DayNight.NoActionBar">
        <!-- Edge-to-edge ready -->
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:windowBackground">@color/oracle_bg</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">false</item>
        <!-- Disable system overscan; reanimated owns transitions -->
        <item name="android:windowAnimationStyle">@null</item>
    </style>

    <!-- Splash theme — shown by Android BEFORE JS bundle is ready.
         Uses the same launch_screen drawable as our SplashScreen so the
         transition into JS is invisible to the user. -->
    <style name="SplashTheme" parent="Theme.AppCompat.NoActionBar">
        <item name="android:windowBackground">@drawable/launch_screen</item>
        <item name="android:statusBarColor">#030E10</item>
        <item name="android:navigationBarColor">#030E10</item>
        <!-- android:windowFullscreen removed: deprecated at targetSdk 35 -->
    </style>
</resources>
