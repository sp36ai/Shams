<?xml version="1.0" encoding="utf-8"?>
<!--
  Android 12+ (API 31+) backup rules.
  We disable cloud + device-transfer backup of MMKV (contains Supabase session
  tokens, quota counters, and cached readings — must not survive device transfer
  without re-auth). Aligns with android:allowBackup="false" in manifest.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </device-transfer>
</data-extraction-rules>
