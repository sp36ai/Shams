<?xml version="1.0" encoding="utf-8"?>
<!--
    Adaptive launcher icon — Shams al-Asrār
    ============================================================
    Used by Android 8.0 (API 26) and above. The system composes
    these two layers and applies a launcher-specific mask
    (circle on Pixel, squircle on OneUI, rounded square on MIUI).

    Layer geometry (Android spec):
      - Total canvas:  108 x 108 dp
      - Visible area:  72 x 72 dp (centered)
      - Safe zone:     66 x 66 dp (must contain meaningful glyph)

    Both raster layers are generated by scripts/generate-launcher-icons.ps1
    at the correct adaptive sizes per density:
      mdpi  108  | hdpi  162  | xhdpi  216  | xxhdpi  324  | xxxhdpi  432
-->
<adaptive-icon xmlns:android="http://schemas.android.com/apk/res/android">
    <background android:drawable="@mipmap/ic_launcher_background" />
    <foreground android:drawable="@mipmap/ic_launcher_foreground" />
</adaptive-icon>
