# ─────────────────────────────────────────────────────────────────────────────
# Shams al-Asrar — Cloud Functions environment variables
#
# Production: store these as Firebase Secret Manager secrets, NOT as plain env.
#   firebase functions:secrets:set RAZORPAY_WEBHOOK_SECRET
#   firebase functions:secrets:set GOOGLE_PLAY_CLIENT_EMAIL
#   firebase functions:secrets:set GOOGLE_PLAY_PRIVATE_KEY
#
# Local emulator: create functions/.env (NOT committed to git) with these values.
# ─────────────────────────────────────────────────────────────────────────────

# Razorpay: Dashboard → Webhooks → Webhook Secret
RAZORPAY_WEBHOOK_SECRET=your-razorpay-webhook-secret-here

# Google Play: Service account JSON → client_email and private_key
GOOGLE_PLAY_CLIENT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GOOGLE_PLAY_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
